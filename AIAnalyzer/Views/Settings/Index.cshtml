@{
    ViewData["Title"] = "Настройки ИИ провайдеров";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');
    :root {
        --set-bg: #0f172a;
        --set-card: #1e293b;
        --set-border: rgba(255, 255, 255, 0.06);
        --set-text: #ffffff;
        --set-text-muted: #94a3b8;
        --set-input-bg: rgba(15, 23, 42, 0.6);
        --set-input-border: rgba(255, 255, 255, 0.08);
        --set-input-focus: rgba(15, 23, 42, 0.9);
        --set-item-bg: rgba(255, 255, 255, 0.02);
        --set-item-hover: rgba(255, 255, 255, 0.04);
        --set-icon-bg: rgba(255, 255, 255, 0.03);
        --set-shadow: rgba(0, 0, 0, 0.4);
        --set-switch-bg: rgba(255, 255, 255, 0.1);
    }
[data-bs-theme="light"], body[data-theme="light"] {
        --set-bg: #f8fafc;
        --set-card: #ffffff;
        --set-border: rgba(0, 0, 0, 0.08);
        --set-text: #0f172a;
        --set-text-muted: #64748b;
        --set-input-bg: #f1f5f9;
        --set-input-border: rgba(0, 0, 0, 0.1);
        --set-input-focus: #ffffff;
        --set-item-bg: rgba(0, 0, 0, 0.02);
        --set-item-hover: rgba(0, 0, 0, 0.04);
        --set-icon-bg: rgba(0, 0, 0, 0.05);
        --set-shadow: rgba(0, 0, 0, 0.06);
        --set-switch-bg: rgba(0, 0, 0, 0.15);
    }

    body {
        background-color: var(--set-bg) !important;
        font-family: 'Inter', sans-serif !important;
        color: var(--set-text) !important;
    }

    .settings-card {
        background: var(--set-card) !important;
        border: 1px solid var(--set-border) !important;
        border-radius: 16px !important;
        box-shadow: 0 12px 30px -10px var(--set-shadow) !important;
        transition: transform 0.3s ease, box-shadow 0.3s ease, background-color 0.3s ease;
        animation: fadeInUp 0.45s ease forwards;
    }

    .section-title { font-weight: 700; letter-spacing: -0.02em; color: var(--set-text); display: flex; align-items: center; gap: 10px; }
    
    .custom-input { 
        background-color: var(--set-input-bg) !important; 
        border: 1px solid var(--set-input-border) !important; 
        border-radius: 10px !important; 
        color: var(--set-text) !important; 
        padding: 10px 14px; 
        font-size: 0.9rem; 
    }
    
    .custom-input:focus { 
        background-color: var(--set-input-focus) !important; 
        border-color: #8b5cf6 !important; 
        outline: none; 
    }

    .form-label { font-size: 0.8rem; font-weight: 600; color: var(--set-text-muted); text-transform: uppercase; margin-bottom: 6px; }

    .custom-switch .form-check-input { background-color: var(--set-switch-bg); cursor: pointer; width: 2.5em; height: 1.25em; }
    .custom-switch .form-check-input:checked { background-color: #8b5cf6; }

    .provider-item-card { 
        background: var(--set-item-bg); 
        border: 1px solid var(--set-border); 
        border-radius: 12px; 
        padding: 16px; 
        margin-bottom: 12px; 
        display: flex; 
        justify-content: space-between; 
        align-items: center; 
    }

    .btn-premium-primary { 
        background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%) !important; 
        border: none !important; color: white !important; border-radius: 10px !important; padding: 10px 20px; font-weight: 600; 
    }

    .provider-item-card {
        background: var(--set-item-bg);
        border: 1px solid var(--set-border);
        border-radius: 12px;
        padding: 16px;
        margin-bottom: 12px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        transition: all 0.2s ease;
        animation: fadeInUp 0.3s ease forwards;
    }

        .provider-item-card:hover {
            background: var(--set-item-hover);
            border-color: rgba(139, 92, 246, 0.3);
            transform: translateX(4px);
        }

        .provider-item-card .fw-bold {
            color: var(--set-text) !important;
        }

        .provider-item-card .text-muted {
            color: var(--set-text-muted) !important;
        }

    .status-badge {
        font-size: 0.72rem;
        font-weight: 700;
        padding: 4px 10px;
        border-radius: 12px;
        text-transform: uppercase;
        letter-spacing: 0.03em;
    }

    .badge-local {
        background: rgba(34, 197, 94, 0.1);
        color: #16a34a;
        border: 1px solid rgba(34, 197, 94, 0.2);
    }

    .badge-cloud {
        background: rgba(59, 130, 246, 0.1);
        color: #2563eb;
        border: 1px solid rgba(59, 130, 246, 0.2);
    }

    [data-bs-theme="dark"] .badge-local, body[data-theme="dark"] .badge-local {
        color: #22c55e;
    }

    [data-bs-theme="dark"] .badge-cloud, body[data-theme="dark"] .badge-cloud {
        color: #3b82f6;
    }

    .btn-premium-primary {
        background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%) !important;
        border: none !important;
        color: white !important;
        border-radius: 10px !important;
        padding: 10px 20px;
        font-weight: 600;
        font-size: 0.9rem;
        box-shadow: 0 4px 15px rgba(139, 92, 246, 0.3) !important;
        transition: all 0.2s ease !important;
    }

        .btn-premium-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(139, 92, 246, 0.5) !important;
        }

    .btn-action-icon {
        background: var(--set-icon-bg);
        border: 1px solid var(--set-border);
        color: var(--set-text-muted);
        width: 34px;
        height: 34px;
        border-radius: 8px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: all 0.15s ease;
    }

        .btn-action-icon:hover {
            color: #ef4444;
            background: rgba(239, 68, 68, 0.1);
            border-color: rgba(239, 68, 68, 0.2);
        }

    .hidden {
        display: none !important;
    }

    .auth-container {
        background: rgba(255,255,255,0.03);
        border: 1px solid var(--set-border);
        border-radius: 12px;
        padding: 15px;
        margin-top: 10px;
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(12px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    ::-webkit-scrollbar {
        width: 6px;
    }

    ::-webkit-scrollbar-track {
        background: transparent;
    }

    ::-webkit-scrollbar-thumb {
        background: rgba(139, 92, 246, 0.2);
        border-radius: 4px;
    }

        ::-webkit-scrollbar-thumb:hover {
            background: rgba(139, 92, 246, 0.4);
        }
</style>

<div class="container py-5" style="max-width: 1200px;">
    <div class="mb-4">
        <a asp-controller="Home" asp-action="Index" class="text-decoration-none text-muted small fw-medium d-inline-flex align-items-center gap-2">
            <i class="bi bi-arrow-left"></i> Вернуться к аналитике матриц
        </a>
    </div>

    <div class="row g-4">
        <div class="col-lg-5">
            <div class="settings-card p-4 h-100">
                <h5 class="section-title mb-4"><i class="bi bi-plus-circle-fill text-primary"></i> Новый интегратор</h5>
                
                <form id="providerForm" class="d-flex flex-column gap-3">
                    <div>
                        <label class="form-label">Условное название</label>
                        <input type="text" id="pName" class="form-control custom-input" placeholder="Например: локальная llama 3" required />
                    </div>
                    <div>
                        <label class="form-label">Адрес шлюза API (Endpoint)</label>
                        <input type="url" id="pApiUrl" class="form-control custom-input" placeholder="http://localhost:1234/v1" required />
                    </div>
                    <div>
                        <label class="form-label">Имя целевой модели</label>
                        <input type="text" id="pModelName" class="form-control custom-input" placeholder="meta-llama-3-8b-instruct" required />
                    </div>

                    <div class="form-check form-switch custom-switch py-2 d-flex align-items-center gap-2">
                        <input class="form-check-input" type="checkbox" id="pIsLocal" onchange="toggleAuthFields()" checked>
                        <label class="form-label mb-0" for="pIsLocal" style="cursor:pointer;">Локальное развертывание</label>
                    </div>

                    <div id="authContainer" class="hidden auth-container">
                        <label class="form-label">Тип провайдера для авторизации</label>
                        <select id="authType" class="form-control custom-input mb-3" onchange="toggleAuthType()">
                            <option value="simple">Стандартный (Обычный API Key)</option>
                            <option value="gigachat">Сбер GigaChat</option>
                        </select>

                        <div id="apiKeyGroup">
                            <label class="form-label" id="apiKeyLabel">Токен авторизации (API Key)</label>
                            <input type="password" id="pApiKey" class="form-control custom-input" placeholder="Введите ключ" />
                            <small id="apiKeyHelp" class="text-muted d-block mt-1 hidden">Вставьте Авторизационные данные из кабинета Сбера (строка начинается на MDE...)</small>
                        </div>

                        <div id="scopeGroup" class="hidden mt-3 pt-3" style="border-top: 1px solid rgba(255,255,255,0.06);">
                            <label class="form-label">Scope (Тип доступа GigaChat)</label>
                            <input type="text" id="pScope" class="form-control custom-input mb-0" placeholder="Например: GIGACHAT_API_CORP" />
                            <small class="text-muted d-block mt-1">Оставьте пустым для стандарта (GIGACHAT_API_PERS)</small>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-premium-primary w-100 mt-2">Подключить провайдер</button>
                </form>
            </div>
        </div>
        <div class="col-lg-7">
            <div class="settings-card p-4 h-100">
                <h5 class="section-title mb-4"><i class="bi bi-cpu-fill text-primary"></i> Активные конфигурации ИИ</h5>
                <div id="providersList"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function toggleAuthFields() {
            const isLocal = document.getElementById("pIsLocal").checked;
            document.getElementById("authContainer").classList.toggle("hidden", isLocal);
        }

        function toggleAuthType() {
            const type = document.getElementById("authType").value;
            const scopeGroup = document.getElementById("scopeGroup");
            const apiKeyLabel = document.getElementById("apiKeyLabel");
            const apiKeyHelp = document.getElementById("apiKeyHelp");

            if (type === "gigachat") {
                scopeGroup.classList.remove("hidden");
                apiKeyLabel.innerText = "Авторизационные данные (Base64)";
                apiKeyHelp.classList.remove("hidden");
            } else {
                scopeGroup.classList.add("hidden");
                apiKeyLabel.innerText = "Токен авторизации (API Key)";
                apiKeyHelp.classList.add("hidden");
            }
        }

        async function loadProviders() {
                    try {
                        const response = await fetch('/Settings/GetProviders');
                        const providers = await response.json();
                        const container = document.getElementById("providersList");
                        container.innerHTML = "";

                        if(providers.length === 0) {
                            container.innerHTML = `
                                <div class="text-center py-5 text-muted opacity-50">
                                    <i class="bi bi-database-exclamation fs-1 d-block mb-3"></i>
                                    Список подключений пуст. Добавьте первый шлюз слева.
                                </div>`;
                            return;
                        }

                        providers.forEach(p => {
                            const badge = p.isLocal
                                ? `<span class="status-badge badge-local"><i class="bi bi-pc-display me-1"></i> Local</span>`
                                : `<span class="status-badge badge-cloud"><i class="bi bi-cloud-fill me-1"></i> Cloud</span>`;

                            const apiKeyHtml = p.apiKey
                                ? `<div class="mt-1"><i class="bi bi-key me-1 opacity-75"></i><span style="word-break: break-all;">${p.apiKey}</span></div>`
                                : '';

                            const scopeHtml = p.scope
                                ? `<div class="mt-1"><i class="bi bi-shield-lock me-1 opacity-75"></i><span style="word-break: break-all;">${p.scope}</span></div>`
                                : '';

                            container.innerHTML += `
                                <div class="provider-item-card align-items-start">
                                    <div class="d-flex align-items-start gap-3 w-100 pe-3">
                                        <div class="rounded-circle p-2 d-flex align-items-center justify-content-center flex-shrink-0" style="background: rgba(139, 92, 246, 0.1); width: 40px; height: 40px;">
                                            <i class="bi bi-hdd-network text-accent" style="color:#8b5cf6; font-size:1.2rem;"></i>
                                        </div>
                                        <div class="flex-grow-1">
                                            <div class="fw-bold mb-2">${p.name}</div>

                                            <div class="text-muted small" style="line-height: 1.6;">
                                                <div><i class="bi bi-box me-1 opacity-75"></i>${p.modelName}</div>
                                                <div class="mt-1"><i class="bi bi-link-45deg me-1 opacity-75"></i><span style="word-break: break-all;">${p.apiUrl}</span></div>
                                                ${apiKeyHtml}
                                                ${scopeHtml}
                                            </div>
                                        </div>
                                    </div>

                                    <div class="d-flex flex-column align-items-end gap-2 flex-shrink-0">
                                        ${badge}
                                        <button type="button" class="btn btn-action-icon mt-auto" title="Удалить конфигурацию" onclick="deleteProvider('${p.id}')">
                                            <i class="bi bi-trash3-fill"></i>
                                        </button>
                                    </div>
                                </div>
                            `;
                        });
                    } catch (error) {
                        console.error("Ошибка загрузки:", error);
                    }
                }

                document.getElementById("providerForm").addEventListener("submit", async (e) => {
                    e.preventDefault();
                    const isLocal = document.getElementById("pIsLocal").checked;
                    const authType = document.getElementById("authType").value;
                    let apiKey = "";
                    let scope = null;

                    if (!isLocal) {
                        apiKey = document.getElementById("pApiKey").value.trim();

                        if (authType === "gigachat") {
                            scope = document.getElementById("pScope").value.trim() || null;
                        }
                    }

                    const response = await fetch('/Settings/AddProvider', {
                        method: 'POST',
                        headers: {'Content-Type': 'application/json'},
                        body: JSON.stringify({
                            name: document.getElementById("pName").value,
                            isLocal: isLocal,
                            modelName: document.getElementById("pModelName").value,
                            apiUrl: document.getElementById("pApiUrl").value,
                            apiKey: apiKey,
                            scope: scope
                        })
                    });

                    if (response.ok) {
                        document.getElementById("providerForm").reset();
                        document.getElementById("pIsLocal").checked = true;

                        // Вызываем наши правильные функции
                        toggleAuthFields();
                        if (typeof toggleAuthType === "function") toggleAuthType();

                        await loadProviders();
                    } else {
                        alert("Не удалось добавить провайдера. Проверьте правильность данных.");
                    }
                });

                async function deleteProvider(id) {
                    if (!confirm("Вы уверены, что хотите удалить эту конфигурацию?")) return;

                    const response = await fetch(`/Settings/DeleteProvider?id=${id}`, {
                        method: 'DELETE'
                    });

                    if (response.ok) {
                        await loadProviders();
                    } else {
                        alert("Ошибка при удалении");
                    }
                }

                document.addEventListener("DOMContentLoaded", () => {
                    // Вызываем правильную функцию инициализации
                    toggleAuthFields();
                    loadProviders();
                });
    </script>
}