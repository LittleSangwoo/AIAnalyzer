@{
    ViewData["Title"] = "Настройки ИИ провайдеров";
}

<div class="container py-5" style="max-width: 1200px;">
    <div class="mb-4">
        <a asp-controller="Home" asp-action="Index" class="text-decoration-none text-muted small fw-medium d-inline-flex align-items-center gap-2">
            <i class="bi bi-arrow-left"></i> Вернуться к аналитике матриц
        </a>
    </div>

    <div class="row g-4">
        <div class="col-lg-5">
            <div class="settings-card p-4 h-100">
                <h5 class="section-title mb-4"><i class="bi bi-plus-circle-fill text-primary"></i> Новый интегратор</h5>
                
                <form id="providerForm" class="d-flex flex-column gap-3">
                    <div>
                        <label class="settings-form-label">Условное название</label>
                        <input type="text" id="pName" class="form-control custom-input" placeholder="Например: локальная llama 3" required />
                    </div>
                    <div>
                        <label class="settings-form-label">Адрес шлюза API (Endpoint)</label>
                        <input type="url" id="pApiUrl" class="form-control custom-input" placeholder="http://localhost:1234/v1" required />
                    </div>
                    <div>
                        <label class="settings-form-label">Имя целевой модели</label>
                        <input type="text" id="pModelName" class="form-control custom-input" placeholder="meta-llama-3-8b-instruct" required />
                    </div>

                    <div class="form-check form-switch custom-switch py-2 d-flex align-items-center gap-2">
                        <input class="form-check-input" type="checkbox" id="pIsLocal" onchange="toggleAuthFields()" checked>
                        <label class="settings-form-label mb-0" for="pIsLocal" style="cursor:pointer;">Локальное развертывание</label>
                    </div>

                    <div id="authContainer" class="hidden auth-container">
                        <label class="settings-form-label">Тип провайдера для авторизации</label>
                        <select id="authType" class="form-control custom-input mb-3" onchange="toggleAuthType()">
                            <option value="simple">Стандартный (Обычный API Key)</option>
                            <option value="gigachat">Сбер GigaChat</option>
                        </select>

                        <div id="apiKeyGroup">
                            <label class="settings-form-label" id="apiKeyLabel">Токен авторизации (API Key)</label>
                            <input type="password" id="pApiKey" class="form-control custom-input" placeholder="Введите ключ" />
                            <small id="apiKeyHelp" class="text-muted d-block mt-1 hidden">Вставьте Авторизационные данные из кабинета Сбера (строка начинается на MDE...)</small>
                        </div>

                        <div id="scopeGroup" class="hidden mt-3 pt-3" style="border-top: 1px solid rgba(255,255,255,0.06);">
                            <label class="settings-form-label">Scope (Тип доступа GigaChat)</label>
                            <input type="text" id="pScope" class="form-control custom-input mb-0" placeholder="Например: GIGACHAT_API_CORP" />
                            <small class="text-muted d-block mt-1">Оставьте пустым для стандарта (GIGACHAT_API_PERS)</small>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-premium-primary w-100 mt-2">Подключить провайдер</button>
                </form>
            </div>
        </div>
        <div class="col-lg-7">
            <div class="settings-card p-4 h-100">
                <h5 class="section-title mb-4"><i class="bi bi-cpu-fill text-primary"></i> Активные конфигурации ИИ</h5>
                <div id="providersList"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Инициализация при загрузке страницы
        document.addEventListener("DOMContentLoaded", () => {
            if (typeof toggleAuthFields === 'function') toggleAuthFields();
            if (typeof loadProviders === 'function') loadProviders();
        });
    </script>
}