@{
    ViewData["Title"] = "Аналитика";
}



<div class="container-fluid" style="height: calc(100vh - 120px);">
    <div class="row g-4 h-100">

        <div class="col-xl-2 col-lg-2 d-flex flex-column h-100">
            <div class="pro-card flex-grow-1 d-flex flex-column">
                <div class="pro-card-header">
                    <h6 class="mb-0 fw-bold"><i class="bi bi-sliders me-2" style="color: var(--app-accent);"></i>Параметры</h6>
                </div>
                <div class="card-body p-4 d-flex flex-column flex-grow-1">
                    <form id="uploadForm" class="mb-5">
                        <label class="form-label small text-muted fw-semibold mb-2">Файлы ответов</label>
                        <input class="form-control form-control-sm mb-3 light-theme-border"
                               style="background-color: var(--app-surface-hover); color: inherit;"
                               type="file" id="answersFiles" accept=".csv,.xlsx" multiple>

                        <div id="fileListContainer" class="d-flex flex-column gap-2 mb-3"></div>

                        <button type="submit" class="btn btn-gradient-primary w-100 fw-semibold py-2 shadow-sm" id="uploadBtn" style="border-radius: 8px;">
                            Загрузить данные
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-xl-5 col-lg-5 d-flex flex-column h-100">
            <div class="pro-card flex-grow-1 d-flex flex-column">
                <div class="pro-card-header pb-3">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h6 class="mb-0 fw-bold"><i class="bi bi-table me-2" style="color: var(--app-accent);"></i>Матрица результатов</h6>
                        <button class="btn btn-sm btn-outline-success fw-semibold shadow-sm light-theme-border"
                                style="border-radius: 8px;" type="button" onclick="downloadExcelReport()">
                            <i class="bi bi-download me-1"></i> Excel
                        </button>
                    </div>

                    <div class="d-flex gap-2">
                        <div class="input-group input-group-sm shadow-sm flex-grow-1 light-theme-border"
                             style="border-radius: 8px; overflow: hidden; border: 1px solid var(--app-border);">
                            <span class="input-group-text border-0" style="background-color: var(--app-surface-hover);">
                                <i class="bi bi-search text-muted"></i>
                            </span>
                            <input type="text" id="searchInput" class="form-control border-0 shadow-none"
                                   style="background-color: var(--app-surface-hover); color: inherit;"
                                   placeholder="Поиск по номеру и вопросу..." onkeyup="filterResults()">
                        </div>

                        <div class="btn-group btn-group-sm shadow-sm flex-shrink-0" role="group" style="border-radius: 8px;">
                            <input type="checkbox" class="btn-check" id="filterRed" value="red" checked autocomplete="off" onchange="filterResults()">
                            <label class="btn btn-outline-danger fw-bold px-3" for="filterRed" title="Красная зона">🔴</label>

                            <input type="checkbox" class="btn-check" id="filterYellow" value="yellow" checked autocomplete="off" onchange="filterResults()">
                            <label class="btn btn-outline-warning fw-bold px-3" for="filterYellow" title="Жёлтая зона">🟡</label>

                            <input type="checkbox" class="btn-check" id="filterGreen" value="green" checked autocomplete="off" onchange="filterResults()">
                            <label class="btn btn-outline-success fw-bold px-3" for="filterGreen" title="Зелёная зона">🟢</label>
                        </div>
                    </div>
                </div>

                <div class="table-responsive scrollable-area flex-grow-1" style="height: 0;">
                    <table class="table table-hover align-middle mb-0 border-0" id="resultsTable">
                        <thead style="background-color: var(--app-surface-hover); position: sticky; top: 0; z-index: 1; box-shadow: 0 1px 2px rgba(0,0,0,0.1);">
                            <tr>
                                <th class="text-center" style="width: 50px;">
                                    <input class="form-check-input elegant-checkbox border-secondary" type="checkbox" id="selectAllCb" title="Выбрать все видимые">
                                </th>
                                <th class="text-muted fw-semibold text-uppercase" style="font-size: 0.85rem;">ID</th>
                                <th class="text-muted fw-semibold text-uppercase" style="font-size: 0.85rem;">Текст вопроса</th>
                                <th class="text-center text-muted fw-semibold text-uppercase" style="font-size: 0.85rem;" title="Правильных ответов">Верно</th>
                                <th class="text-center text-muted fw-semibold text-uppercase" style="font-size: 0.85rem;" title="Количество ошибок">Ошибки</th>
                                <th class="text-center text-muted fw-semibold text-uppercase" style="font-size: 0.85rem;" title="Процент ошибок">% ошибок</th>
                            </tr>
                        </thead>
                        <tbody id="resultsBody">
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <i class="bi bi-inbox fs-1 d-block mb-3 opacity-25"></i>
                                    Ожидание загрузки файлов
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-xl-5 col-lg-5 d-flex flex-column h-100">
            <div class="pro-card flex-grow-1 d-flex flex-column">

                <div class="pro-card-header ai-panel-header">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h6 class="mb-0 fw-bold">
                            <i class="bi bi-magic me-2" style="color: var(--app-accent);"></i>Интеллектуальный анализ
                        </h6>
                        <div class="d-flex align-items-center gap-2">
                            <button class="btn btn-sm border-0 px-2 opacity-50" type="button" onclick="clearHistory()"
                                    title="Очистить историю" style="font-size: 0.75rem; border-radius: 6px; background: var(--app-surface-hover);">
                                <i class="bi bi-trash3"></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0" aria-labelledby="modelDropdown" style="border-radius: 12px; font-size: 0.85rem; background-color: var(--app-surface-hover);">
                                <li><a class="dropdown-item model-select-item active" href="#" data-val="groq">Groq (Llama 3)</a></li>
                                <li><a class="dropdown-item model-select-item" href="#" data-val="gigachat">GigaChat Pro</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item model-select-item fw-bold text-success" href="#" data-val="local"><i class="bi bi-pc-display me-2"></i>Локальная сеть (LM Studio)</a></li>
                            </ul>
                            <input type="hidden" id="modelSelect" value="groq">
                            <div class="dropdown light-theme-border" style="border-radius: 20px; border: 1px solid var(--app-border);">
                                <button class="btn btn-sm border-0 dropdown-toggle px-3 fw-semibold" type="button"
                                        id="modelDropdown" data-bs-toggle="dropdown" aria-expanded="false"
                                        style="border-radius: 20px; font-size: 0.78rem; background-color: var(--app-surface-hover); color: inherit;">
                                    <i class="bi bi-cpu text-primary me-1"></i>
                                    <span id="selectedModelText">Загрузка...</span>
                                </button>
                                <ul id="dynamicModelList" class="dropdown-menu dropdown-menu-end shadow border-0" aria-labelledby="modelDropdown"
                                    style="border-radius: 12px; font-size: 0.85rem; background-color: var(--app-surface-hover);">
                                    <li><span class="dropdown-item text-muted">Загрузка ИИ...</span></li>
                                </ul>
                                <input type="hidden" id="modelSelect" value="">
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mb-2">
                        <button type="button" class="btn btn-ai-action btn-sm flex-fill" onclick="sendToAi('rewrite')"
                                data-bs-toggle="tooltip" data-bs-placement="top"
                                title="Анализирует текст выбранных вопросов и предлагает более понятные формулировки.">
                            <i class="bi bi-pencil-square text-primary"></i>
                            <span>Улучшить текст</span>
                        </button>
                        <button type="button" class="btn btn-ai-action btn-sm flex-fill" onclick="sendToAi('course_redesign')"
                                data-bs-toggle="tooltip" data-bs-placement="top"
                                title="Оценивает структуру курса на основе ошибок студентов.">
                            <i class="bi bi-book text-warning"></i>
                            <span>Аудит курса</span>
                        </button>
                        <button type="button" class="btn btn-ai-action btn-sm flex-fill" onclick="sendToAi('test_redesign')"
                                data-bs-toggle="tooltip" data-bs-placement="top"
                                title="Советы по изменению формата тестирования.">
                            <i class="bi bi-sliders text-success"></i>
                            <span>Формат теста</span>
                        </button>
                    </div>

                    <div class="d-flex align-items-center light-theme-border"
                         style="border-radius: 25px; border: 1px solid var(--app-border); background-color: var(--app-surface-hover); padding: 4px 6px;">
                        <input type="text" id="customPrompt" class="form-control border-0 shadow-none bg-transparent"
                               placeholder="Задайте свой вопрос ИИ..."
                               style="font-size: 0.88rem; color: inherit;"
                               onkeypress="if(event.key === 'Enter') sendCustomPrompt()">
                        <button class="btn btn-primary d-flex align-items-center justify-content-center flex-shrink-0"
                                type="button" onclick="sendCustomPrompt()"
                                style="border-radius: 50%; width: 30px; height: 30px; padding: 0;">
                            <i class="bi bi-send-fill" style="font-size: 0.8rem;"></i>
                        </button>
                    </div>
                </div>

                <div class="card-body p-3 d-flex flex-column flex-grow-1" style="height: 0;">
                    <div id="ai-output"
                         class="scrollable-area flex-grow-1"
                         style="height: 0; overflow-y: auto; padding-right: 2px;">
                        <div class="ai-welcome">
                            <i class="bi bi-stars me-2 text-primary"></i>Готов к работе. Выберите вопросы в таблице слева и нажмите нужный инструмент, либо задайте свой вопрос.
                        </div>
                    </div>
                </div>

            </div>
        </div>

    </div>
</div>

<button class="btn btn-info text-white rounded-circle shadow-lg d-flex align-items-center justify-content-center"
        style="position: fixed; bottom: 30px; right: 30px; width: 56px; height: 56px; z-index: 1050; font-size: 1.4rem; transition: transform 0.2s;"
        data-bs-toggle="modal" data-bs-target="#helpModal"
        onmouseover="this.style.transform='scale(1.1)'" onmouseout="this.style.transform='scale(1)'">
    <i class="bi bi-question-lg"></i>
</button>

<div class="modal fade" id="helpModal" tabindex="-1" aria-labelledby="helpModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable modal-lg">
        <div class="modal-content shadow-lg border-0"
             style="border-radius: 16px; background-color: var(--app-surface-hover); color: inherit;">
            <div class="modal-header text-white"
                 style="background: linear-gradient(135deg, var(--app-primary), var(--app-accent)); border-top-left-radius: 16px; border-top-right-radius: 16px;">
                <h5 class="modal-title fw-bold" id="helpModalLabel">
                    <i class="bi bi-info-circle-fill me-2"></i>Как пользоваться программой
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Закрыть"></button>
            </div>
            <div class="modal-body p-4 fs-6" style="line-height: 1.6;">
                <p class="lead fw-semibold">Добро пожаловать в систему аналитики! Здесь вы можете легко проверить, насколько хорошо студенты справляются с тестами.</p>
                <hr style="border-color: var(--app-border);">

                <h6 class="fw-bold text-primary mt-4"><i class="bi bi-1-circle-fill me-2"></i>Шаг 1. Загрузка ваших данных</h6>
                <p>В левой колонке <b>«Параметры»</b> нажмите на кнопку <i>«Выберите файлы»</i>. Найдите на компьютере файлы в формате Excel (.xlsx или .csv) с ответами студентов. Вы можете выбирать и добавлять несколько файлов по очереди. Затем нажмите синюю кнопку <b>«Загрузить данные»</b>.</p>

                <h6 class="fw-bold text-primary mt-4"><i class="bi bi-2-circle-fill me-2"></i>Шаг 2. Изучение результатов</h6>
                <p>В центральной колонке появится таблица со всеми вопросами. Программа сразу раскрашивает их для вашего удобства:</p>
                <ul>
                    <li>🔴 <b>Красные строки:</b> Самые сложные вопросы. Студенты делают тут больше всего ошибок.</li>
                    <li>🟡 <b>Жёлтые строки:</b> Вопросы средней сложности. Есть ошибки, но не критично.</li>
                    <li>🟢 <b>Зелёные строки:</b> Идеальные вопросы. Почти все ответили верно.</li>
                </ul>
                <p><i class="bi bi-lightbulb text-warning me-1"></i><i>Секрет:</i> Вы можете нажимать на круглые кнопки 🔴🟡🟢 над таблицей, чтобы скрыть или показать нужные цвета.</p>

                <h6 class="fw-bold text-primary mt-4"><i class="bi bi-3-circle-fill me-2"></i>Шаг 3. Умный помощник (Нейросеть)</h6>
                <p>В правой колонке живёт ваш личный виртуальный ассистент. Он поможет исправить сложные вопросы.</p>
                <ol>
                    <li>Поставьте галочки слева от самых сложных (красных) вопросов в таблице.</li>
                    <li>
                        Нажмите одну из трёх кнопок:
                        <ul>
                            <li>✏️ <b>Улучшить текст:</b> Ассистент перепишет ваш вопрос так, чтобы студенты перестали в нём путаться.</li>
                            <li>📘 <b>Аудит курса:</b> Ассистент подскажет, какую тему нужно объяснить студентам ещё раз.</li>
                            <li>🎛 <b>Формат теста:</b> Ассистент посоветует, как переделать варианты ответов (например, убрать слишком очевидные).</li>
                        </ul>
                    </li>
                </ol>
                <p class="text-muted small mb-0">
                    <i class="bi bi-lightbulb-fill text-warning me-1"></i>
                    Если вы не выберете вопросы галочками, ассистент автоматически проанализирует все красные вопросы за вас.
                </p>
                <h6 class="fw-bold text-primary mt-4"><i class="bi bi-4-circle-fill me-2"></i>Шаг 4. Выгрузка отчета</h6>
                <p>
                    Вы можете в любой момент выгрузить результаты вашего анализа в удобный файл. 
                    Нажмите кнопку <b>«<i class="bi bi-download me-1"></i> Excel»</b> в заголовке таблицы 
                    «Матрица результатов». Программа создаст файл, содержащий текущую статистику 
                    по вопросам и все ваши рекомендации от ИИ, которые были сгенерированы в чате.
                </p>
                <h6 class="fw-bold text-primary mt-4"><i class="bi me-2"></i>Дополнительные функциии</h6>
                <ul class="mb-0">
                    <li>
                        <b>История диалога.</b> Каждый ответ ИИ сохраняется в чате — вы можете сравнивать результаты разных запросов, не теряя предыдущие. Для очистки нажмите кнопку
                        <i class="bi bi-trash3 mx-1"></i> в правом верхнем углу панели ассистента.
                    </li>
                    <li class="mt-2">
                        <b>Копирование ответа.</b> У каждого сообщения есть кнопка <i class="bi bi-copy mx-1"></i><b>Копировать</b> — она мгновенно копирует текст ответа в буфер обмена.
                    </li>
                    <li class="mt-2">
                        <b>Свой вопрос.</b> Вы можете задать ассистенту любой вопрос в поле ввода внизу панели — он ответит в той же истории. Нажмите Enter или кнопку <i class="bi bi-send-fill mx-1"></i>.
                    </li>
                    <li class="mt-2">
                        <b>Выбор модели.</b> Переключайтесь между <b>разными моделями нейросети</b> через селектор в правом верхнем углу панели.
                    </li>
                </ul>
            </div>
            <div class="modal-footer light-theme-border" style="border-top: 1px solid var(--app-border); border-bottom-left-radius: 16px; border-bottom-right-radius: 16px;">
                <button type="button" class="btn btn-secondary px-4 fw-bold" data-bs-dismiss="modal" style="border-radius: 8px;">Понятно, спасибо!</button>
            </div>
        </div>
    </div>
</div>


                        @section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <script>
        // Инициализация специфична для этой страницы
        document.addEventListener("DOMContentLoaded", () => {
            if (typeof marked !== 'undefined') marked.use({ breaks: true, gfm: true });
            document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(el => new bootstrap.Tooltip(el));
            
            // Если функции loadModelDropdown и loadHistory уже есть в site.js,
            // они будут вызваны автоматически, но если нужно принудительно:
            if(typeof loadModelDropdown === 'function') loadModelDropdown();
            if(typeof loadHistory === 'function') loadHistory();
        });
    </script>
}