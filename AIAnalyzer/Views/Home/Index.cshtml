@{
    ViewData["Title"] = "AI Агент - Анализ тестов";
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-md-3">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-dark text-white fw-bold">
                    Загрузите Excel/CSV-файлы
                </div>
                <div class="card-body bg-light">
                    <form id="uploadForm">
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Эталон ответов:</label>
                            <input class="form-control form-control-sm" type="file" id="etalonFile" accept=".csv,.xlsx" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Массив ответов:</label>
                            <input class="form-control form-control-sm" type="file" id="answersFile" accept=".csv,.xlsx" required>
                        </div>
                        <button type="submit" class="btn btn-primary w-100" id="uploadBtn">
                            Upload & Analyze
                        </button>
                    </form>
                    <div id="uploadStatus" class="alert mt-3 d-none p-2 text-center small"></div>
                </div>
            </div>
            
            <div id="aiSettingsBlock">
                <div class="card shadow-sm border-info mb-3">
                    <div class="card-header bg-info text-dark fw-bold">Промпты (AI)</div>
                    <div class="card-body">
                        <p class="text-muted small mb-2">Функционал в разработке (Шаг 2)...</p>
                        <button class="btn btn-outline-dark btn-sm w-100 mb-2">Compare</button>
                        <button class="btn btn-outline-danger btn-sm w-100 mb-2">Critical</button>
                        <button class="btn btn-outline-success btn-sm w-100">Report</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-9">
            <h5 class="mb-3">Результаты анализа (Светофор)</h5>
            <div class="table-responsive shadow-sm rounded">
                <table class="table table-hover align-middle mb-0" id="resultsTable">
                    <thead class="table-light">
                        <tr>
                            <th width="10%">ID</th>
                            <th width="50%">Текст вопроса</th>
                            <th width="10%" class="text-success">Верно</th>
                            <th width="10%" class="text-danger">Ошибок</th>
                            <th width="20%">Зона</th>
                        </tr>
                    </thead>
                    <tbody id="resultsBody">
                        <tr>
                            <td colspan="5" class="text-center text-muted py-5">
                                Ожидание файлов... Загрузите массив ответов и эталон.
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Функция для отправки данных в твой API-контроллер ИИ
        async function sendToAi(promptType) {
            // Читаем массив объектов QuestionStatDto, который напарница положит в window.loadedQuestions
            const questions = window.loadedQuestions;

            if (!questions || questions.length === 0) {
                alert("Сначала загрузите и обработайте файлы через форму слева!");
                return;
            }

            const modelProvider = document.getElementById("modelSelect").value;
            const outputBlock = document.getElementById("ai-output");

            // Включаем лоадер загрузки
            outputBlock.innerHTML = `
                <div class="d-flex align-items-center text-primary fw-bold">
                    <div class="spinner-border spinner-border-sm me-2" role="status"></div>
                    Нейросеть (${modelProvider}) формирует аналитику, пожалуйста, подождите...
                </div>`;

            try {
                // Делаем асинхронный POST запрос на твой контроллер
                const response = await fetch('/api/ai/analyze', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        questions: questions,
                        promptType: promptType,
                        modelProvider: modelProvider
                    })
                });

                if (!response.ok) throw new Error(`Ошибка сервера: ${response.status}`);

                const result = await response.json();

                // Сохраняем текстовый ответ ИИ в твою переменную (понадобится для ClosedXML)
                window.aiRecommendation = result.text;

                // Выводим сгенерированный текст
                outputBlock.innerText = result.text;

            } catch (error) {
                outputBlock.innerHTML = `<span class="text-danger fw-bold"><i class="bi bi-x-circle"></i> Ошибка при вызове ИИ: ${error.message}</span>`;
            }
        }

        // Функция для скачивания готового отчета ClosedXML
        async function downloadExcelReport() {
            const questions = window.loadedQuestions;
            if (!questions || questions.length === 0) {
                alert("Нет данных для экспорта отчета!");
                return;
            }

            const aiRecommendation = window.aiRecommendation || "Анализ ИИ не проводился.";

            try {
                // Делаем запрос на твой эндпоинт экспорта
                const response = await fetch('/api/ai/export', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        questions: questions,
                        aiRecommendation: aiRecommendation
                    })
                });

                if (!response.ok) throw new Error("Не удалось сгенерировать Excel файл.");

                // Получаем файл как Blob и автоматически запускаем скачивание в браузере
                const blob = await response.blob();
                const url = window.URL.createObjectURL(blob);
                const a = document.createElement('a');
                a.href = url;
                a.download = "AI_Analyzer_Total_Report.xlsx";
                document.body.appendChild(a);
                a.click();
                a.remove();
                window.URL.revokeObjectURL(url);

            } catch (error) {
                alert("Ошибка при скачивании файла: " + error.message);
            }
        }
    </script>
}