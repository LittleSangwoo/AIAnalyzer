@{
    ViewData["Title"] = "AI Агент - Анализ тестов";
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-md-3">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-dark text-white fw-bold">
                    <i class="bi bi-file-earmark-excel"></i> Загрузка Excel/CSV
                </div>
                <div class="card-body bg-light">
                    <form id="uploadForm">
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Массив ответов (выберите один или несколько файлов):</label>
                            <input class="form-control form-control-sm" type="file" id="answersFiles" name="answersFiles" accept=".csv,.xlsx" multiple required>
                        </div>
                        <button type="submit" class="btn btn-primary w-100" id="uploadBtn">
                            <i class="bi bi-upload"></i> Upload & Analyze
                        </button>
                    </form>
                    <div id="uploadStatus" class="alert mt-3 d-none p-2 text-center small"></div>
                </div>
            </div>

            <div id="aiSettingsBlock">
                <div class="card shadow-sm border-info mb-3">
                    <div class="card-header bg-info text-dark fw-bold">
                        <i class="bi bi-robot"></i> Управление ИИ
                    </div>
                    <div class="card-body bg-light">
                        <div class="mb-3">
                            <label for="modelSelect" class="form-label small fw-bold">Выберите нейросеть:</label>
                            <select class="form-select form-select-sm border-secondary" id="modelSelect">
                                <option value="deepseek" selected>DeepSeek Chat</option>
                                <option value="gigachat">Сбер GigaChat</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label for="apiKeyInput" class="form-label small fw-bold">API Ключ:</label>
                            <input type="password" class="form-control form-control-sm" id="apiKeyInput" placeholder="Введите ключ">
                        </div>

                        <label class="form-label small fw-bold d-block">Режим анализа:</label>
                        <div class="d-grid gap-2">
                            <button type="button" class="btn btn-outline-primary btn-sm text-start fw-bold" onclick="sendToAi('rewrite')">
                                <i class="bi bi-pencil-square"></i> Rewrite (Переформулировать)
                            </button>
                            <button type="button" class="btn btn-outline-danger btn-sm text-start fw-bold" onclick="sendToAi('course_redesign')">
                                <i class="bi bi-book"></i> Course Redesign
                            </button>
                            <button type="button" class="btn btn-outline-success btn-sm text-start fw-bold" onclick="sendToAi('test_redesign')">
                                <i class="bi bi-gear"></i> Test Redesign
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-9">
            
            <div class="card shadow-sm mb-4 border-primary">
                <div class="card-header bg-white text-primary d-flex justify-content-between align-items-center py-3">
                    <h6 class="mb-0 fw-bold"><i class="bi bi-bar-chart-steps"></i> Этап 1: Первичная статистика</h6>
                    <div>
                        <button class="btn btn-sm btn-outline-primary me-2" type="button" id="toggleTableBtn" data-bs-toggle="collapse" data-bs-target="#collapseTable" aria-expanded="true">
                            <i class="bi bi-arrows-collapse"></i> Свернуть таблицу
                        </button>
                        <span class="badge bg-primary text-white rounded-pill small">Точные данные</span>
                    </div>
                </div>
    
                <div id="collapseTable" class="collapse show">
                    <div class="table-responsive rounded-bottom">
                        <table class="table table-hover align-middle mb-0" id="resultsTable">
                            <thead class="table-light text-secondary small">
                                <tr>
                                    <th>ID</th>
                                    <th>Текст вопроса</th>
                                    <th>Верно</th>
                                    <th>Ошибок</th>
                                    <th>% Ошибок</th>
                                </tr>
                            </thead>
                            <tbody id="resultsBody">
                                <tr>
                                    <td colspan="5" class="text-center text-muted py-5">Загрузите файлы ответов слева.</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm mb-4 border-info">
                <div class="card-header bg-white text-info d-flex justify-content-between align-items-center py-3">
                    <h6 class="mb-0 fw-bold text-dark"><i class="bi bi-cpu text-info"></i> Этап 2: Заключение нейросети</h6>
                </div>
                <div class="card-body bg-light">
                    <div id="ai-output" class="p-3 rounded text-dark bg-white border" style="min-height: 120px; white-space: pre-wrap; font-size: 0.95rem;">Ожидание запуска ИИ...</div>
                </div>
            </div>
            
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const uploadForm = document.getElementById('uploadForm');
            const collapseTable = document.getElementById('collapseTable');
            const toggleTableBtn = document.getElementById('toggleTableBtn');

            // Логика изменения текста и иконки кнопки Свернуть/Развернуть
            collapseTable.addEventListener('hidden.bs.collapse', function () {
                toggleTableBtn.innerHTML = '<i class="bi bi-arrows-expand"></i> Развернуть таблицу';
            });

            collapseTable.addEventListener('shown.bs.collapse', function () {
                toggleTableBtn.innerHTML = '<i class="bi bi-arrows-collapse"></i> Свернуть таблицу';
            });

            uploadForm.addEventListener('submit', async function (e) {
                e.preventDefault();
                const files = document.getElementById('answersFiles').files;
                const btn = document.getElementById('uploadBtn');



                if (files.length === 0) return;

                btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Анализируем...';
                btn.disabled = true;

                const formData = new FormData();
                for (let i = 0; i < files.length; i++) {
                    formData.append('answersFiles', files[i]);
                }

                try {
                    const response = await fetch('/api/analyzer/upload', {
                        method: 'POST',
                        body: formData
                    });
                    
                    if (!response.ok) throw new Error('Ошибка обработки файлов');

                    const data = await response.json();
                    
                    // Защита от разного регистра в сериализаторе JSON
                    const questionsList = data.questions || data.Questions || [];
                    window.loadedQuestions = questionsList;
                    renderTable(questionsList);
                    
                } catch (error) {
                    alert("Ошибка: " + error.message);
                } finally {
                    btn.innerHTML = '<i class="bi bi-upload"></i> Upload & Analyze';
                    btn.disabled = false;
                }
            });
        });

        function renderTable(questions) {
            const tbody = document.getElementById('resultsBody');
            tbody.innerHTML = '';
            
            if (!questions || questions.length === 0) {
                 tbody.innerHTML = '<tr><td colspan="6" class="text-center text-muted py-5">Нет данных для анализа.</td></tr>';
                 return;
            }

            questions.forEach(q => {
                const tr = document.createElement('tr');
                
                // Страховка регистра (PascalCase / camelCase)
                const zoneVal = q.zone !== undefined ? q.zone : q.Zone;
                const errs = q.errorsCount !== undefined ? q.errorsCount : q.ErrorsCount;
                const corrs = q.correctCount !== undefined ? q.correctCount : q.CorrectCount;
                const qId = q.questionId || q.QuestionId;
                const qText = q.questionText || q.QuestionText;

                // Считаем процент на лету
                const total = errs + corrs;
                const percent = total > 0 ? Math.round((errs / total) * 100) : 0;

                // Настраиваем цвета и текст зоны (с поддержкой числового Enum и строкового значения)
                let zoneLabel = "Зеленая";
                let badgeClass = "bg-success";
                let rowClass = "table-success";

                if (zoneVal === 2 || String(zoneVal).toLowerCase() === 'red') {
                    zoneLabel = "Красная";
                    badgeClass = "bg-danger";
                    rowClass = "table-danger";
                } else if (zoneVal === 1 || String(zoneVal).toLowerCase() === 'yellow') {
                    zoneLabel = "Желтая";
                    badgeClass = "bg-warning text-dark";
                    rowClass = "table-warning";
                }

                tr.className = rowClass;
                tr.innerHTML = `
                    <td class="fw-bold">${qId}</td>
                    <td>${qText}</td>
                    <td>${corrs}</td>
                    <td>${errs}</td>
                    <td>${percent}%</td>
                `;
                tbody.appendChild(tr);
            });
        }

        async function sendToAi(promptType) {
            if (!window.loadedQuestions) {
                alert("Сначала загрузите и проанализируйте файлы.");
                return;
            }
            
            const aiOutput = document.getElementById('ai-output');
            
            // Поддержка обеих нотаций для Zone
            const redZone = window.loadedQuestions.filter(q => {
                 const z = q.zone !== undefined ? q.zone : q.Zone;
                 return z === 2 || String(z).toLowerCase() === 'red';
            });
            
            aiOutput.innerText = "Генерация рекомендаций...";
            
            try {
                const response = await fetch('/api/ai/recommendation', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        redZoneQuestions: redZone,
                        promptType: promptType,
                        modelProvider: document.getElementById('modelSelect').value
                    })
                });
                
                aiOutput.innerText = await response.text();
            } catch (error) {
                aiOutput.innerText = "Ошибка при обращении к ИИ: " + error.message;
            }
        }
    </script>
}