@{
    ViewData["Title"] = "Аналитика";
}

<style>
    .btn-check:checked + .btn-outline-danger {
        background-color: #dc3545;
        color: white;
        border-color: #dc3545;
    }

    .btn-check:checked + .btn-outline-warning {
        background-color: #ffc107;
        color: black;
        border-color: #ffc107;
    }

    .btn-check:checked + .btn-outline-success {
        background-color: #198754;
        color: white;
        border-color: #198754;
    }

    @@media (prefers-color-scheme: light) {
        html:not([data-bs-theme="dark"]) .pro-card {
            border: 1px solid #ced4da !important;
            box-shadow: 0 0.25rem 0.5rem rgba(0, 0, 0, 0.05) !important;
        }

        html:not([data-bs-theme="dark"]) .light-theme-border {
            border-color: #ced4da !important;
        }
    }

    html[data-bs-theme="light"] .pro-card, body[data-theme="light"] .pro-card {
        border: 1px solid #ced4da !important;
        box-shadow: 0 0.25rem 0.5rem rgba(0, 0, 0, 0.05) !important;
    }

    html[data-bs-theme="light"] .light-theme-border, body[data-theme="light"] .light-theme-border {
        border-color: #ced4da !important;
    }

    /* ── AI Chat styles ── */
    .ai-chat-history {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .ai-chat-bubble {
        position: relative;
        padding: 12px 14px;
        border-radius: 12px;
        background-color: var(--app-surface-hover);
        border: 1px solid var(--app-border);
        font-size: 0.88rem;
        line-height: 1.55;
    }

        .ai-chat-bubble .bubble-meta {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 6px;
            gap: 8px;
        }

        .ai-chat-bubble .bubble-label {
            font-size: 0.72rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.04em;
            color: var(--app-accent, #0d6efd);
            opacity: 0.8;
            white-space: nowrap;
        }

        .ai-chat-bubble .bubble-copy-btn {
            flex-shrink: 0;
            background: none;
            border: 1px solid var(--app-border);
            border-radius: 6px;
            padding: 2px 7px;
            font-size: 0.72rem;
            cursor: pointer;
            color: inherit;
            opacity: 0.55;
            transition: opacity 0.15s, background 0.15s;
            display: flex;
            align-items: center;
            gap: 4px;
        }

            .ai-chat-bubble .bubble-copy-btn:hover {
                opacity: 1;
                background-color: rgba(13,110,253,0.1);
            }

            .ai-chat-bubble .bubble-copy-btn.copied {
                color: #198754;
                opacity: 1;
                border-color: #198754;
            }

    .ai-markdown-content {
        font-size: 0.88rem;
        color: inherit;
    }

        .ai-markdown-content h1, .ai-markdown-content h2, .ai-markdown-content h3 {
            font-size: 1rem;
            font-weight: 700;
            color: var(--app-accent, #0d6efd);
            margin-top: 0.85rem;
            margin-bottom: 0.4rem;
        }

        .ai-markdown-content p {
            margin-bottom: 0.6rem;
        }

            .ai-markdown-content p:last-child {
                margin-bottom: 0;
            }

        .ai-markdown-content ul, .ai-markdown-content ol {
            padding-left: 1.3rem;
            margin-bottom: 0.75rem;
        }

        .ai-markdown-content li {
            margin-bottom: 0.2rem;
        }

        .ai-markdown-content strong {
            font-weight: 600;
        }

    /* ── Compact action buttons ── */
    .btn-ai-action {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 2px;
        padding: 6px 4px !important;
        line-height: 1.2;
        border-radius: 10px !important;
        background-color: var(--app-surface-hover);
        border: 1px solid var(--app-border) !important;
        color: inherit;
        font-size: 0.75rem !important;
        transition: background 0.15s, box-shadow 0.15s;
    }

        .btn-ai-action:hover {
            background-color: rgba(13,110,253,0.07);
            box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        }

        .btn-ai-action i {
            font-size: 1.1rem !important;
        }

    /* ── Thinking indicator ── */
    .ai-thinking {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.82rem;
        color: var(--app-accent, #0d6efd);
        font-weight: 600;
        padding: 8px 0;
    }

    /* ── Welcome placeholder ── */
    .ai-welcome {
        opacity: 0.6;
        font-size: 0.88rem;
        padding: 8px 0;
    }

    /* Compact header in right panel */
    .ai-panel-header {
        padding-bottom: 8px !important;
    }
</style>

<div class="container-fluid" style="height: calc(100vh - 120px);">
    <div class="row g-4 h-100">

        <!-- ── LEFT: Parameters ── -->
        <div class="col-xl-2 col-lg-2 d-flex flex-column h-100">
            <div class="pro-card flex-grow-1 d-flex flex-column">
                <div class="pro-card-header">
                    <h6 class="mb-0 fw-bold"><i class="bi bi-sliders me-2" style="color: var(--app-accent);"></i>Параметры</h6>
                </div>
                <div class="card-body p-4 d-flex flex-column flex-grow-1">
                    <form id="uploadForm" class="mb-5">
                        <label class="form-label small text-muted fw-semibold mb-2">Файлы ответов</label>
                        <input class="form-control form-control-sm mb-3 light-theme-border"
                               style="background-color: var(--app-surface-hover); color: inherit;"
                               type="file" id="answersFiles" accept=".csv,.xlsx" multiple>

                        <div id="fileListContainer" class="d-flex flex-column gap-2 mb-3"></div>

                        <button type="submit" class="btn btn-gradient-primary w-100 fw-semibold py-2 shadow-sm" id="uploadBtn" style="border-radius: 8px;">
                            Загрузить данные
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- ── CENTER: Results table ── -->
        <div class="col-xl-5 col-lg-5 d-flex flex-column h-100">
            <div class="pro-card flex-grow-1 d-flex flex-column">
                <div class="pro-card-header pb-3">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h6 class="mb-0 fw-bold"><i class="bi bi-table me-2" style="color: var(--app-accent);"></i>Матрица результатов</h6>
                        <button class="btn btn-sm btn-outline-success fw-semibold shadow-sm light-theme-border"
                                style="border-radius: 8px;" type="button" onclick="exportToExcel()">
                            <i class="bi bi-download me-1"></i> Excel
                        </button>
                    </div>

                    <div class="d-flex gap-2">
                        <div class="input-group input-group-sm shadow-sm flex-grow-1 light-theme-border"
                             style="border-radius: 8px; overflow: hidden; border: 1px solid var(--app-border);">
                            <span class="input-group-text border-0" style="background-color: var(--app-surface-hover);">
                                <i class="bi bi-search text-muted"></i>
                            </span>
                            <input type="text" id="searchInput" class="form-control border-0 shadow-none"
                                   style="background-color: var(--app-surface-hover); color: inherit;"
                                   placeholder="Поиск по номеру и вопросу..." onkeyup="filterResults()">
                        </div>

                        <div class="btn-group btn-group-sm shadow-sm flex-shrink-0" role="group" style="border-radius: 8px;">
                            <input type="checkbox" class="btn-check" id="filterRed" value="red" checked autocomplete="off" onchange="filterResults()">
                            <label class="btn btn-outline-danger fw-bold px-3" for="filterRed" title="Красная зона">🔴</label>

                            <input type="checkbox" class="btn-check" id="filterYellow" value="yellow" checked autocomplete="off" onchange="filterResults()">
                            <label class="btn btn-outline-warning fw-bold px-3" for="filterYellow" title="Жёлтая зона">🟡</label>

                            <input type="checkbox" class="btn-check" id="filterGreen" value="green" checked autocomplete="off" onchange="filterResults()">
                            <label class="btn btn-outline-success fw-bold px-3" for="filterGreen" title="Зелёная зона">🟢</label>
                        </div>
                    </div>
                </div>

                <div class="table-responsive scrollable-area flex-grow-1" style="height: 0;">
                    <table class="table table-hover align-middle mb-0 border-0" id="resultsTable">
                        <thead style="background-color: var(--app-surface-hover); position: sticky; top: 0; z-index: 1; box-shadow: 0 1px 2px rgba(0,0,0,0.1);">
                            <tr>
                                <th class="text-center" style="width: 50px;">
                                    <input class="form-check-input elegant-checkbox border-secondary" type="checkbox" id="selectAllCb" title="Выбрать все видимые">
                                </th>
                                <th class="text-muted fw-semibold text-uppercase" style="font-size: 0.85rem;">ID</th>
                                <th class="text-muted fw-semibold text-uppercase" style="font-size: 0.85rem;">Текст вопроса</th>
                                <th class="text-center text-muted fw-semibold text-uppercase" style="font-size: 0.85rem;" title="Правильных ответов">Верно</th>
                                <th class="text-center text-muted fw-semibold text-uppercase" style="font-size: 0.85rem;" title="Количество ошибок">Ошибки</th>
                                <th class="text-center text-muted fw-semibold text-uppercase" style="font-size: 0.85rem;" title="Процент ошибок">% ошибок</th>
                            </tr>
                        </thead>
                        <tbody id="resultsBody">
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <i class="bi bi-inbox fs-1 d-block mb-3 opacity-25"></i>
                                    Ожидание загрузки файлов
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- ── RIGHT: AI panel ── -->
        <div class="col-xl-5 col-lg-5 d-flex flex-column h-100">
            <div class="pro-card flex-grow-1 d-flex flex-column">

                <!-- Header: title + model selector -->
                <div class="pro-card-header ai-panel-header">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h6 class="mb-0 fw-bold">
                            <i class="bi bi-magic me-2" style="color: var(--app-accent);"></i>Интеллектуальный анализ
                        </h6>
                        <div class="d-flex align-items-center gap-2">
                            <!-- Clear history -->
                            <button class="btn btn-sm border-0 px-2 opacity-50" type="button" onclick="clearHistory()"
                                    title="Очистить историю" style="font-size: 0.75rem; border-radius: 6px; background: var(--app-surface-hover);">
                                <i class="bi bi-trash3"></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0" aria-labelledby="modelDropdown" style="border-radius: 12px; font-size: 0.85rem; background-color: var(--app-surface-hover);">
                                <li><a class="dropdown-item model-select-item active" href="#" data-val="groq">Groq (Llama 3)</a></li>
                                <li><a class="dropdown-item model-select-item" href="#" data-val="gigachat">GigaChat Pro</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item model-select-item fw-bold text-success" href="#" data-val="local"><i class="bi bi-pc-display me-2"></i>Локальная сеть (LM Studio)</a></li>
                            </ul>
                            <input type="hidden" id="modelSelect" value="groq">
                            <!-- Model selector -->
                            <div class="dropdown light-theme-border" style="border-radius: 20px; border: 1px solid var(--app-border);">
                                <button class="btn btn-sm border-0 dropdown-toggle px-3 fw-semibold" type="button"
                                        id="modelDropdown" data-bs-toggle="dropdown" aria-expanded="false"
                                        style="border-radius: 20px; font-size: 0.78rem; background-color: var(--app-surface-hover); color: inherit;">
                                    <i class="bi bi-cpu text-primary me-1"></i>
                                    <span id="selectedModelText">Groq (Llama 3)</span>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end shadow border-0" aria-labelledby="modelDropdown"
                                    style="border-radius: 12px; font-size: 0.85rem; background-color: var(--app-surface-hover);">
                                    <li><a class="dropdown-item model-select-item active" href="#" data-val="groq">Groq (Llama 3)</a></li>
                                    <li><a class="dropdown-item model-select-item" href="#" data-val="gigachat">GigaChat Pro</a></li>
                                </ul>
                                <input type="hidden" id="modelSelect" value="groq">
                            </div>
                        </div>
                    </div>

                    <!-- Action buttons: compact row -->
                    <div class="d-flex gap-2 mb-2">
                        <button type="button" class="btn btn-ai-action btn-sm flex-fill" onclick="sendToAi('rewrite')"
                                data-bs-toggle="tooltip" data-bs-placement="top"
                                title="Анализирует текст выбранных вопросов и предлагает более понятные формулировки.">
                            <i class="bi bi-pencil-square text-primary"></i>
                            <span>Улучшить текст</span>
                        </button>
                        <button type="button" class="btn btn-ai-action btn-sm flex-fill" onclick="sendToAi('course_redesign')"
                                data-bs-toggle="tooltip" data-bs-placement="top"
                                title="Оценивает структуру курса на основе ошибок студентов.">
                            <i class="bi bi-book text-warning"></i>
                            <span>Аудит курса</span>
                        </button>
                        <button type="button" class="btn btn-ai-action btn-sm flex-fill" onclick="sendToAi('test_redesign')"
                                data-bs-toggle="tooltip" data-bs-placement="top"
                                title="Советы по изменению формата тестирования.">
                            <i class="bi bi-sliders text-success"></i>
                            <span>Формат теста</span>
                        </button>
                    </div>

                    <!-- Custom prompt input -->
                    <div class="d-flex align-items-center light-theme-border"
                         style="border-radius: 25px; border: 1px solid var(--app-border); background-color: var(--app-surface-hover); padding: 4px 6px;">
                        <input type="text" id="customPrompt" class="form-control border-0 shadow-none bg-transparent"
                               placeholder="Задайте свой вопрос ИИ..."
                               style="font-size: 0.88rem; color: inherit;"
                               onkeypress="if(event.key === 'Enter') sendCustomPrompt()">
                        <button class="btn btn-primary d-flex align-items-center justify-content-center flex-shrink-0"
                                type="button" onclick="sendCustomPrompt()"
                                style="border-radius: 50%; width: 30px; height: 30px; padding: 0;">
                            <i class="bi bi-send-fill" style="font-size: 0.8rem;"></i>
                        </button>
                    </div>
                </div>

                <!-- Chat history area -->
                <div class="card-body p-3 d-flex flex-column flex-grow-1" style="height: 0;">
                    <div id="ai-output"
                         class="scrollable-area flex-grow-1"
                         style="height: 0; overflow-y: auto; padding-right: 2px;">
                        <div class="ai-welcome">
                            <i class="bi bi-stars me-2 text-primary"></i>Готов к работе. Выберите вопросы в таблице слева и нажмите нужный инструмент, либо задайте свой вопрос.
                        </div>
                    </div>
                </div>

            </div>
        </div>

    </div>
</div>

<!-- Help button -->
<button class="btn btn-info text-white rounded-circle shadow-lg d-flex align-items-center justify-content-center"
        style="position: fixed; bottom: 30px; right: 30px; width: 56px; height: 56px; z-index: 1050; font-size: 1.4rem; transition: transform 0.2s;"
        data-bs-toggle="modal" data-bs-target="#helpModal"
        onmouseover="this.style.transform='scale(1.1)'" onmouseout="this.style.transform='scale(1)'">
    <i class="bi bi-question-lg"></i>
</button>

<!-- Help modal -->
<div class="modal fade" id="helpModal" tabindex="-1" aria-labelledby="helpModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable modal-lg">
        <div class="modal-content shadow-lg border-0"
             style="border-radius: 16px; background-color: var(--app-surface-hover); color: inherit;">
            <div class="modal-header text-white"
                 style="background: linear-gradient(135deg, var(--app-primary), var(--app-accent)); border-top-left-radius: 16px; border-top-right-radius: 16px;">
                <h5 class="modal-title fw-bold" id="helpModalLabel">
                    <i class="bi bi-info-circle-fill me-2"></i>Как пользоваться программой
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Закрыть"></button>
            </div>
            <div class="modal-body p-4 fs-6" style="line-height: 1.6;">
                <p class="lead fw-semibold">Добро пожаловать в систему аналитики! Здесь вы можете легко проверить, насколько хорошо студенты справляются с тестами.</p>
                <hr style="border-color: var(--app-border);">

                <h6 class="fw-bold text-primary mt-4"><i class="bi bi-1-circle-fill me-2"></i>Шаг 1. Загрузка ваших данных</h6>
                <p>В левой колонке <b>«Параметры»</b> нажмите на кнопку <i>«Выберите файлы»</i>. Найдите на компьютере файлы в формате Excel (.xlsx или .csv) с ответами студентов. Вы можете выбирать и добавлять несколько файлов по очереди. Затем нажмите синюю кнопку <b>«Загрузить данные»</b>.</p>

                <h6 class="fw-bold text-primary mt-4"><i class="bi bi-2-circle-fill me-2"></i>Шаг 2. Изучение результатов</h6>
                <p>В центральной колонке появится таблица со всеми вопросами. Программа сразу раскрашивает их для вашего удобства:</p>
                <ul>
                    <li>🔴 <b>Красные строки:</b> Самые сложные вопросы. Студенты делают тут больше всего ошибок.</li>
                    <li>🟡 <b>Жёлтые строки:</b> Вопросы средней сложности. Есть ошибки, но не критично.</li>
                    <li>🟢 <b>Зелёные строки:</b> Идеальные вопросы. Почти все ответили верно.</li>
                </ul>
                <p><i class="bi bi-lightbulb text-warning me-1"></i><i>Секрет:</i> Вы можете нажимать на круглые кнопки 🔴🟡🟢 над таблицей, чтобы скрыть или показать нужные цвета.</p>

                <h6 class="fw-bold text-primary mt-4"><i class="bi bi-3-circle-fill me-2"></i>Шаг 3. Умный помощник (Нейросеть)</h6>
                <p>В правой колонке живёт ваш личный виртуальный ассистент. Он поможет исправить сложные вопросы.</p>
                <ol>
                    <li>Поставьте галочки слева от самых сложных (красных) вопросов в таблице.</li>
                    <li>
                        Нажмите одну из трёх кнопок:
                        <ul>
                            <li>✏️ <b>Улучшить текст:</b> Ассистент перепишет ваш вопрос так, чтобы студенты перестали в нём путаться.</li>
                            <li>📘 <b>Аудит курса:</b> Ассистент подскажет, какую тему нужно объяснить студентам ещё раз.</li>
                            <li>🎛 <b>Формат теста:</b> Ассистент посоветует, как переделать варианты ответов (например, убрать слишком очевидные).</li>
                        </ul>
                    </li>
                </ol>
                <p class="text-muted small mb-0">
                    <i class="bi bi-lightbulb-fill text-warning me-1"></i>
                    Если вы не выберете вопросы галочками, ассистент автоматически проанализирует все красные вопросы за вас.
                </p>

                <hr style="border-color: var(--app-border);">

                <h6 class="fw-bold text-primary mt-3"><i class="bi bi-stars me-2"></i>Новые возможности</h6>
                <ul class="mb-0">
                    <li>
                        <b>История диалога.</b> Каждый ответ ИИ теперь сохраняется в чате — вы можете сравнивать результаты разных запросов, не теряя предыдущие. Для очистки нажмите кнопку
                        <i class="bi bi-trash3 mx-1"></i> в правом верхнем углу панели ассистента.
                    </li>
                    <li class="mt-2">
                        <b>Копирование ответа.</b> У каждого сообщения ИИ есть кнопка <i class="bi bi-copy mx-1"></i><b>Копировать</b> — она мгновенно копирует текст ответа в буфер обмена, чтобы вы могли вставить его в любой документ.
                    </li>
                    <li class="mt-2">
                        <b>Свой вопрос.</b> Вы можете задать ассистенту любой вопрос в поле ввода внизу панели — он ответит в той же истории. Нажмите Enter или кнопку <i class="bi bi-send-fill mx-1"></i>.
                    </li>
                    <li class="mt-2">
                        <b>Выбор модели.</b> Переключайтесь между <b>Groq (Llama 3)</b> и <b>GigaChat Pro</b> через селектор в правом верхнем углу панели.
                    </li>
                </ul>
            </div>
            <div class="modal-footer light-theme-border" style="border-top: 1px solid var(--app-border); border-bottom-left-radius: 16px; border-bottom-right-radius: 16px;">
                <button type="button" class="btn btn-secondary px-4 fw-bold" data-bs-dismiss="modal" style="border-radius: 8px;">Понятно, спасибо!</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>

    <script>
        let selectedFiles = [];

        // ── File list ──────────────────────────────────────────────────
        window.removeFile = function(index) {
            selectedFiles.splice(index, 1);
            renderFileList();
        };

        function renderFileList() {
            const container = document.getElementById('fileListContainer');
            container.innerHTML = '';
            selectedFiles.forEach((file, index) => {
                const item = document.createElement('div');
                item.className = 'd-flex justify-content-between align-items-center p-2 rounded small shadow-sm light-theme-border';
                item.style.cssText = 'border: 1px solid var(--app-border); background-color: var(--app-surface-hover);';
                item.innerHTML = `
                    <span class="text-truncate" style="max-width: 85%;" title="${file.name}">
                        <i class="bi bi-file-earmark-text me-2 text-primary"></i>${file.name}
                    </span>
                    <button type="button" class="btn-close" style="font-size: 0.6rem;" onclick="removeFile(${index})"></button>
                `;
                container.appendChild(item);
            });
        }

        // ── Chat history ───────────────────────────────────────────────
        const LABEL_MAP = {
            rewrite:         '✏️ Улучшить текст',
            course_redesign: '📘 Аудит курса',
            test_redesign:   '🎛 Формат теста',
            custom:          '💬 Свой вопрос',
        };

        function clearHistory() {
            const out = document.getElementById('ai-output');
            out.innerHTML = '<div class="ai-welcome"><i class="bi bi-stars me-2 text-primary"></i>История очищена. Готов к новым запросам.</div>';
        }

        function showThinking(text) {
            const out = document.getElementById('ai-output');
            // Remove any existing thinking indicator
            const existing = out.querySelector('.ai-thinking');
            if (existing) existing.remove();

            const el = document.createElement('div');
            el.className = 'ai-thinking';
            el.innerHTML = `<div class="spinner-grow spinner-grow-sm text-primary" role="status"></div><span>${text}</span>`;
            out.appendChild(el);
            out.scrollTop = out.scrollHeight;
            return el;
        }

        function appendBubble(label, markdownText) {
            const out = document.getElementById('ai-output');

            // Remove welcome placeholder on first real message
            const welcome = out.querySelector('.ai-welcome');
            if (welcome) welcome.remove();

            const bubble = document.createElement('div');
            bubble.className = 'ai-chat-bubble';

            const parsed = (typeof marked !== 'undefined')
                ? marked.parse(markdownText)
                : markdownText.replace(/\n/g, '<br>');

            bubble.innerHTML = `
                <div class="bubble-meta">
                    <span class="bubble-label">${label}</span>
                    <button class="bubble-copy-btn" onclick="copyBubble(this)" title="Копировать ответ">
                        <i class="bi bi-copy"></i> Копировать
                    </button>
                </div>
                <div class="ai-markdown-content">${parsed}</div>
            `;

            out.appendChild(bubble);
            out.scrollTop = out.scrollHeight;
        }

        window.copyBubble = function(btn) {
            const content = btn.closest('.ai-chat-bubble').querySelector('.ai-markdown-content');
            const text = content ? content.innerText : '';
            navigator.clipboard.writeText(text).then(() => {
                btn.classList.add('copied');
                btn.innerHTML = '<i class="bi bi-check2"></i> Скопировано';
                setTimeout(() => {
                    btn.classList.remove('copied');
                    btn.innerHTML = '<i class="bi bi-copy"></i> Копировать';
                }, 2000);
            });
        };

        // ── AI response helper ─────────────────────────────────────────
        async function processAiResponse(response, thinkingEl, label) {
            if (thinkingEl) thinkingEl.remove();
            if (!response.ok) throw new Error(await response.text());

            let rawText = await response.text();
            let parsedText = rawText;
            try { parsedText = JSON.parse(rawText); } catch(e) {}

            appendBubble(label, parsedText);
        }

        // ── DOMContentLoaded ───────────────────────────────────────────
        document.addEventListener("DOMContentLoaded", function () {
            if (typeof marked !== 'undefined') {
                marked.use({ breaks: true, gfm: true });
            }

            document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(el => new bootstrap.Tooltip(el));

            document.querySelectorAll('.model-select-item').forEach(item => {
                item.addEventListener('click', function(e) {
                    e.preventDefault();
                    document.querySelectorAll('.model-select-item').forEach(el => el.classList.remove('active', 'fw-bold'));
                    this.classList.add('active', 'fw-bold');
                    document.getElementById('modelSelect').value = this.getAttribute('data-val');
                    document.getElementById('selectedModelText').innerText = this.innerText;
                });
            });

            document.getElementById('answersFiles').addEventListener('change', function(e) {
                selectedFiles = selectedFiles.concat(Array.from(e.target.files));
                renderFileList();
                e.target.value = '';
            });

            document.getElementById('selectAllCb').addEventListener('change', function(e) {
                document.querySelectorAll('.question-cb').forEach(cb => {
                    if (cb.closest('tr').style.display !== 'none') cb.checked = e.target.checked;
                });
            });

            document.getElementById('uploadForm').addEventListener('submit', async function(e) {
                e.preventDefault();
                const btn = document.getElementById('uploadBtn');

                if (selectedFiles.length === 0) {
                    alert("Пожалуйста, добавьте файлы для загрузки.");
                    return;
                }

                btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Обработка...';
                btn.disabled = true;

                const formData = new FormData();
                selectedFiles.forEach(f => formData.append('answersFiles', f));

                try {
                    const response = await fetch('/api/analyzer/upload', { method: 'POST', body: formData });
                    if (!response.ok) throw new Error('Сбой при парсинге файлов');

                    const data = await response.json();
                    const questionsList = data.questions || data.Questions || [];
                    window.loadedQuestions = questionsList;
                    renderTable(questionsList);

                    document.getElementById('searchInput').value = '';
                    document.getElementById('filterRed').checked = true;
                    document.getElementById('filterYellow').checked = true;
                    document.getElementById('filterGreen').checked = true;
                    filterResults();

                    selectedFiles = [];
                    renderFileList();
                } catch (error) {
                    alert("Ошибка системы: " + error.message);
                } finally {
                    btn.innerHTML = 'Загрузить данные';
                    btn.disabled = false;
                }
            });
        });

        // ── Table helpers ──────────────────────────────────────────────
        function filterResults() {
            const search = document.getElementById('searchInput').value.toLowerCase();
            const showRed    = document.getElementById('filterRed').checked;
            const showYellow = document.getElementById('filterYellow').checked;
            const showGreen  = document.getElementById('filterGreen').checked;

            document.querySelectorAll('#resultsBody tr.data-row').forEach(row => {
                const matchText = row.getAttribute('data-qtext').includes(search) ||
                                  row.getAttribute('data-qid').includes(search);
                const zone = row.getAttribute('data-qzone');
                const matchZone = (zone === 'red' && showRed) ||
                                  (zone === 'yellow' && showYellow) ||
                                  (zone === 'green' && showGreen);

                if (matchText && matchZone) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                    row.querySelector('.question-cb').checked = false;
                }
            });
            updateSelectAllCb();
        }

        function updateSelectAllCb() {
            const visible = Array.from(document.querySelectorAll('.question-cb'))
                .filter(cb => cb.closest('tr').style.display !== 'none');
            const checked = visible.filter(cb => cb.checked);
            document.getElementById('selectAllCb').checked = visible.length > 0 && visible.length === checked.length;
        }

        function renderTable(questions) {
            const tbody = document.getElementById('resultsBody');
            tbody.innerHTML = '';
            document.getElementById('selectAllCb').checked = false;

            if (!questions || questions.length === 0) {
                tbody.innerHTML = `<tr><td colspan="6" class="text-center text-muted py-5">Выборка пуста.</td></tr>`;
                return;
            }

            questions.forEach(q => {
                const zoneVal  = q.zone          !== undefined ? q.zone          : q.Zone;
                const errs     = q.errorsCount   !== undefined ? q.errorsCount   : q.ErrorsCount;
                const corrs    = q.correctCount  !== undefined ? q.correctCount  : q.CorrectCount;
                const qId      = q.questionId    || q.QuestionId;
                const qText    = String(q.questionText || q.QuestionText || '');
                const percent  = q.errorPercentage !== undefined ? q.errorPercentage : q.ErrorPercentage;

                let rowClass = 'zone-row-green', zoneStr = 'green';
                if (zoneVal === 2 || String(zoneVal).toLowerCase() === 'red')    { rowClass = 'zone-row-red';    zoneStr = 'red'; }
                else if (zoneVal === 1 || String(zoneVal).toLowerCase() === 'yellow') { rowClass = 'zone-row-yellow'; zoneStr = 'yellow'; }

                const tr = document.createElement('tr');
                tr.className = rowClass + ' data-row border-bottom';
                tr.setAttribute('data-qtext', qText.toLowerCase());
                tr.setAttribute('data-qid', String(qId).toLowerCase());
                tr.setAttribute('data-qzone', zoneStr);
                tr.innerHTML = `
                    <td class="text-center align-middle border-end border-light">
                        <input class="form-check-input elegant-checkbox question-cb border-secondary" type="checkbox" value="${qId}">
                    </td>
                    <td class="fw-bold opacity-75">${qId}</td>
                    <td class="py-3 pe-3 border-end border-light">${qText}</td>
                    <td class="text-success fw-bold text-center">${corrs}</td>
                    <td class="text-danger fw-bold text-center">${errs}</td>
                    <td class="text-center fw-bold opacity-75">${percent}%</td>
                `;
                tr.querySelector('.question-cb').addEventListener('change', updateSelectAllCb);
                tbody.appendChild(tr);
            });
        }

        // ── Export ─────────────────────────────────────────────────────
        function exportToExcel() {
            if (typeof XLSX === 'undefined') { alert("Библиотека Excel ещё не загрузилась."); return; }
            if (!window.loadedQuestions || window.loadedQuestions.length === 0) { alert("Нет данных для выгрузки."); return; }

            const visibleIds = Array.from(document.querySelectorAll('#resultsBody tr.data-row'))
                .filter(tr => tr.style.display !== 'none')
                .map(tr => tr.querySelector('.question-cb').value);

            const filtered = window.loadedQuestions.filter(q => visibleIds.includes(String(q.questionId || q.QuestionId)));
            if (filtered.length === 0) { alert("Нет данных, удовлетворяющих фильтру."); return; }

            const excelData = filtered.map(q => {
                const zoneVal = q.zone !== undefined ? q.zone : q.Zone;
                let zoneText = 'Зелёная';
                if (zoneVal === 2 || String(zoneVal).toLowerCase() === 'red')    zoneText = 'Красная';
                else if (zoneVal === 1 || String(zoneVal).toLowerCase() === 'yellow') zoneText = 'Жёлтая';
                return {
                    "Идентификатор":      q.questionId    || q.QuestionId,
                    "Текст вопроса":      q.questionText  || q.QuestionText,
                    "Правильных ответов": q.correctCount  !== undefined ? q.correctCount  : q.CorrectCount,
                    "Количество ошибок":  q.errorsCount   !== undefined ? q.errorsCount   : q.ErrorsCount,
                    "Процент ошибок (%)": q.errorPercentage !== undefined ? q.errorPercentage : q.ErrorPercentage,
                    "Зона риска":         zoneText
                };
            });

            const ws = XLSX.utils.json_to_sheet(excelData);
            ws['!cols'] = [{ wch: 15 }, { wch: 80 }, { wch: 20 }, { wch: 20 }, { wch: 20 }, { wch: 15 }];
            const wb = XLSX.utils.book_new();
            XLSX.utils.book_append_sheet(wb, ws, "Статистика");
            XLSX.writeFile(wb, `Статистика_курса_${new Date().toLocaleDateString('ru-RU')}.xlsx`);
        }

        // ── AI calls ───────────────────────────────────────────────────
        async function sendToAi(promptType) {
            if (!window.loadedQuestions || window.loadedQuestions.length === 0) {
                alert("Сначала загрузите матрицу данных.");
                return;
            }

            const checkedIds = Array.from(document.querySelectorAll('.question-cb:checked')).map(cb => cb.value);
            let targetQuestions = [];

            if (promptType === 'course_redesign' || promptType === 'test_redesign') {
                targetQuestions = [...window.loadedQuestions].sort((a, b) => {
                    const errA = a.errorPercentage !== undefined ? a.errorPercentage : a.ErrorPercentage;
                    const errB = b.errorPercentage !== undefined ? b.errorPercentage : b.ErrorPercentage;
                    return errB - errA;
                });
            } else {
                if (checkedIds.length > 0) {
                    targetQuestions = window.loadedQuestions.filter(q => checkedIds.includes(String(q.questionId || q.QuestionId)));
                } else {
                    targetQuestions = window.loadedQuestions.filter(q => {
                        const z = q.zone !== undefined ? q.zone : q.Zone;
                        return z === 2 || String(z).toLowerCase() === 'red';
                    });
                }
            }

            if (targetQuestions.length === 0) {
                appendBubble(LABEL_MAP[promptType] || promptType, 'Нет вопросов для анализа. Выберите вопросы галочками.');
                return;
            }

            const thinkingEl = showThinking(`ИИ изучает ${targetQuestions.length} вопросов…`);

            try {
                const [response] = await Promise.all([
                    fetch('/api/ai/recommendation', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            redZoneQuestions: targetQuestions,
                            promptType: promptType,
                            modelProvider: document.getElementById('modelSelect').value,
                            apiKey: ""
                        })
                    }),
                    new Promise(r => setTimeout(r, 900))
                ]);
                await processAiResponse(response, thinkingEl, LABEL_MAP[promptType] || promptType);
            } catch (error) {
                if (thinkingEl) thinkingEl.remove();
                appendBubble('⚠️ Ошибка', error.message);
            }
        }

        async function sendCustomPrompt() {
            const prompt = document.getElementById('customPrompt').value.trim();
            if (!prompt) { alert("Введите текст запроса."); return; }

            const thinkingEl = showThinking('Обдумываю ответ…');

            try {
                const [response] = await Promise.all([
                    fetch('/api/ai/custom', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            prompt: prompt,
                            modelProvider: document.getElementById('modelSelect').value,
                            apiKey: ""
                        })
                    }),
                    new Promise(r => setTimeout(r, 900))
                ]);
                await processAiResponse(response, thinkingEl, `💬 ${prompt.length > 50 ? prompt.slice(0, 50) + '…' : prompt}`);
                document.getElementById('customPrompt').value = '';
            } catch (error) {
                if (thinkingEl) thinkingEl.remove();
                appendBubble('⚠️ Ошибка', error.message);
            }
        }
    </script>
}
