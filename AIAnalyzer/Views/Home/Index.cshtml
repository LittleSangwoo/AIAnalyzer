@{
    ViewData["Title"] = "Аналитика";
}

<div class="container-fluid" style="height: calc(100vh - 120px);">
    <div class="row g-4 h-100">

        <div class="col-xl-2 col-lg-3 d-flex flex-column h-100">
            <div class="pro-card flex-grow-1">
                <div class="pro-card-header">
                    <h6 class="mb-0 fw-bold"><i class="bi bi-sliders me-2" style="color: var(--app-accent);"></i>Параметры</h6>
                </div>
                <div class="card-body p-4 d-flex flex-column">
                    <form id="uploadForm" class="mb-5">
                        <label class="form-label small text-muted fw-semibold mb-2">Файлы ответов</label>
                        <input class="form-control form-control-sm mb-3" style="background-color: var(--app-surface-hover); border-color: var(--app-border);" type="file" id="answersFiles" accept=".csv,.xlsx" multiple required>
                        <button type="submit" class="btn btn-gradient-primary w-100 fw-semibold py-2" id="uploadBtn">
                            Загрузить данные
                        </button>
                    </form>

                    <div class="mt-auto">
                        <h6 class="fw-bold mb-3 fs-6">Доступ к нейросети</h6>
                        <label class="form-label small text-muted fw-semibold">Провайдер</label>
                        <select class="form-select form-select-sm mb-3" id="modelSelect" style="background-color: var(--app-surface-hover); border-color: var(--app-border);">
                            <option value="groq" selected>Groq (Llama 3)</option>
                            <option value="gigachat">GigaChat Pro</option>
                        </select>

                        <label class="form-label small text-muted fw-semibold">API Ключ</label>
                        <div class="input-group input-group-sm shadow-sm" style="border-radius: 8px; overflow: hidden; border: 1px solid var(--app-border);">
                            <input type="password" class="form-control border-0" id="apiKeyInput" placeholder="Введите токен..." style="background-color: var(--app-surface-hover);">
                            <button class="btn btn-light border-0" type="button" title="Добавить ключ в систему (в разработке)" style="background-color: var(--app-surface-hover);">
                                <i class="bi bi-plus-circle text-primary"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-6 col-lg-5 d-flex flex-column h-100">
            <div class="pro-card flex-grow-1">
                <div class="pro-card-header d-flex justify-content-between align-items-center">
                    <h6 class="mb-0 fw-bold"><i class="bi bi-table me-2" style="color: var(--app-accent);"></i>Матрица результатов</h6>
                    <button class="btn btn-sm btn-outline-success fw-semibold" style="border-radius: 8px;" type="button" onclick="exportToExcel()">
                        <i class="bi bi-download me-1"></i> Excel
                    </button>
                </div>

                <div class="table-responsive scrollable-area flex-grow-1" style="height: 0;">
                    <table class="table table-hover align-middle mb-0 border-0" id="resultsTable">
                        <thead style="background-color: var(--app-surface-hover); position: sticky; top: 0; z-index: 1;">
                            <tr>
                                <th class="text-center" style="width: 50px;">
                                    <input class="form-check-input elegant-checkbox" type="checkbox" id="selectAllCb" title="Выбрать все">
                                </th>
                                <th class="text-muted fw-semibold text-uppercase" style="font-size: 0.8em;">ID</th>
                                <th class="text-muted fw-semibold text-uppercase" style="font-size: 0.8em;">Текст вопроса</th>
                                <th class="text-center text-muted fw-semibold text-uppercase" style="font-size: 0.8em;">Верно</th>
                                <th class="text-center text-muted fw-semibold text-uppercase" style="font-size: 0.8em;">Ошибки</th>
                                <th class="text-center text-muted fw-semibold text-uppercase" style="font-size: 0.8em;">%</th>
                            </tr>
                        </thead>
                        <tbody id="resultsBody">
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <i class="bi bi-inbox fs-1 d-block mb-3 opacity-25"></i>
                                    Ожидание загрузки файлов
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-xl-4 col-lg-4 d-flex flex-column h-100">
            <div class="pro-card flex-grow-1">
                <div class="pro-card-header border-0 pb-0">
                    <h6 class="mb-3 fw-bold"><i class="bi bi-magic me-2" style="color: var(--app-accent);"></i>Интеллектуальный анализ</h6>

                    <div class="d-flex gap-2 mb-2">
                        <button type="button" class="btn btn-ai-action btn-sm flex-fill fw-semibold py-2 shadow-sm" onclick="sendToAi('rewrite')">
                            <i class="bi bi-pencil-square text-primary mb-1 d-block fs-5"></i> Улучшить текст
                        </button>
                        <button type="button" class="btn btn-ai-action btn-sm flex-fill fw-semibold py-2 shadow-sm" onclick="sendToAi('course_redesign')">
                            <i class="bi bi-book text-warning mb-1 d-block fs-5"></i> Аудит курса
                        </button>
                        <button type="button" class="btn btn-ai-action btn-sm flex-fill fw-semibold py-2 shadow-sm" onclick="sendToAi('test_redesign')">
                            <i class="bi bi-sliders text-success mb-1 d-block fs-5"></i> Формат теста
                        </button>
                    </div>

                    <div class="input-group input-group-sm shadow-sm mb-3" style="border-radius: 8px; overflow: hidden;">
                        <input type="text" id="customPrompt" class="form-control border-0" style="background-color: var(--app-surface-hover);" placeholder="Задайте свой вопрос ИИ...">
                        <button class="btn btn-dark fw-semibold px-3 border-0" type="button" onclick="sendCustomPrompt()">
                            <i class="bi bi-send-fill"></i>
                        </button>
                    </div>
                </div>

                <div class="card-body p-4 d-flex flex-column">
                    <div id="ai-output" class="ai-assistant-panel scrollable-area">
                        <span class="opacity-50"><i class="bi bi-stars me-2"></i>Готов к работе. Выберите вопросы в таблице слева и нажмите на нужный инструмент, либо задайте свой вопрос. Если вопросы не выбраны, ассистент проанализирует всю «Красную зону».</span>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const uploadForm = document.getElementById('uploadForm');

            document.getElementById('selectAllCb').addEventListener('change', function(e) {
                const cbs = document.querySelectorAll('.question-cb');
                cbs.forEach(cb => cb.checked = e.target.checked);
            });

            uploadForm.addEventListener('submit', async function (e) {
                e.preventDefault();
                const files = document.getElementById('answersFiles').files;
                const btn = document.getElementById('uploadBtn');

                if (files.length === 0) return;

                btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Обработка...';
                btn.disabled = true;

                const formData = new FormData();
                for (let i = 0; i < files.length; i++) {
                    formData.append('answersFiles', files[i]);
                }

                try {
                    const response = await fetch('/api/analyzer/upload', {
                        method: 'POST',
                        body: formData
                    });

                    if (!response.ok) throw new Error('Сбой при парсинге файлов');

                    const data = await response.json();
                    const questionsList = data.questions || data.Questions || [];
                    window.loadedQuestions = questionsList;
                    renderTable(questionsList);

                } catch (error) {
                    alert("Ошибка системы: " + error.message);
                } finally {
                    btn.innerHTML = 'Загрузить данные';
                    btn.disabled = false;
                }
            });
        });

        function renderTable(questions) {
            const tbody = document.getElementById('resultsBody');
            tbody.innerHTML = '';
            document.getElementById('selectAllCb').checked = false;

            if (!questions || questions.length === 0) {
                 tbody.innerHTML = `<tr><td colspan="6" class="text-center text-muted py-5">Выборка пуста.</td></tr>`;
                 return;
            }

            questions.forEach((q, index) => {
                const tr = document.createElement('tr');

                const zoneVal = q.zone !== undefined ? q.zone : q.Zone;
                const errs = q.errorsCount !== undefined ? q.errorsCount : q.ErrorsCount;
                const corrs = q.correctCount !== undefined ? q.correctCount : q.CorrectCount;
                const qId = q.questionId || q.QuestionId;
                const qText = q.questionText || q.QuestionText;
                const percent = q.errorPercentage !== undefined ? q.errorPercentage : q.ErrorPercentage;

                let rowClass = "zone-row-green";
                if (zoneVal === 2 || String(zoneVal).toLowerCase() === 'red') {
                    rowClass = "zone-row-red";
                } else if (zoneVal === 1 || String(zoneVal).toLowerCase() === 'yellow') {
                    rowClass = "zone-row-yellow";
                }

                tr.className = rowClass;
                tr.innerHTML = `
                    <td class="text-center align-middle">
                        <input class="form-check-input elegant-checkbox question-cb" type="checkbox" value="${qId}">
                    </td>
                    <td class="fw-bold opacity-75">${qId}</td>
                    <td class="py-3 pe-3">${qText}</td>
                    <td class="text-success fw-bold text-center">${corrs}</td>
                    <td class="text-danger fw-bold text-center">${errs}</td>
                    <td class="text-center fw-bold opacity-75">${percent}%</td>
                `;
                tbody.appendChild(tr);
            });
        }

        function exportToExcel() {
            if (typeof XLSX === 'undefined') {
                alert("Библиотека Excel еще не загрузилась. Подождите секунду.");
                return;
            }
            if (!window.loadedQuestions || window.loadedQuestions.length === 0) {
                alert("Нет данных для выгрузки.");
                return;
            }
            const excelData = window.loadedQuestions.map(q => {
                const zoneVal = q.zone !== undefined ? q.zone : q.Zone;
                let zoneText = "Зеленая";
                if (zoneVal === 2 || String(zoneVal).toLowerCase() === 'red') zoneText = "Красная";
                else if (zoneVal === 1 || String(zoneVal).toLowerCase() === 'yellow') zoneText = "Желтая";

                return {
                    "Идентификатор": q.questionId || q.QuestionId,
                    "Текст вопроса": q.questionText || q.QuestionText,
                    "Правильных ответов": q.correctCount !== undefined ? q.correctCount : q.CorrectCount,
                    "Количество ошибок": q.errorsCount !== undefined ? q.errorsCount : q.ErrorsCount,
                    "Процент ошибок (%)": q.errorPercentage !== undefined ? q.errorPercentage : q.ErrorPercentage,
                    "Зона риска": zoneText
                };
            });
            const worksheet = XLSX.utils.json_to_sheet(excelData);
            worksheet['!cols'] = [{ wch: 15 }, { wch: 80 }, { wch: 20 }, { wch: 20 }, { wch: 20 }, { wch: 15 }];
            const workbook = XLSX.utils.book_new();
            XLSX.utils.book_append_sheet(workbook, worksheet, "Статистика");
            XLSX.writeFile(workbook, `Статистика_курса_${new Date().toLocaleDateString('ru-RU')}.xlsx`);
        }

        async function sendToAi(promptType) {
            if (!window.loadedQuestions) {
                alert("Сначала загрузите матрицу данных.");
                return;
            }

            const apiKey = document.getElementById('apiKeyInput').value.trim();
            const aiOutput = document.getElementById('ai-output');
            const checkedIds = Array.from(document.querySelectorAll('.question-cb:checked')).map(cb => cb.value);
            let targetQuestions = [];

            if (checkedIds.length > 0) {
                targetQuestions = window.loadedQuestions.filter(q => checkedIds.includes(q.questionId || q.QuestionId));
            } else {
                targetQuestions = window.loadedQuestions.filter(q => {
                     const z = q.zone !== undefined ? q.zone : q.Zone;
                     return z === 2 || String(z).toLowerCase() === 'red';
                });

                if (targetQuestions.length === 0) {
                    aiOutput.innerHTML = '<div class="text-success fw-bold d-flex align-items-center"><i class="bi bi-check-circle-fill fs-4 me-2"></i> Нет вопросов в красной зоне. Ручной выбор также пуст.</div>';
                    return;
                }
            }

            aiOutput.innerHTML = `
                <div class="d-flex align-items-center mb-3">
                    <div class="spinner-grow spinner-grow-sm text-primary me-2" role="status"></div>
                    <span class="fw-semibold text-primary">Ассистент анализирует данные...</span>
                </div>
                <div class="opacity-50 small">Обрабатывается вопросов: ${targetQuestions.length}</div>
            `;

            try {
                const fetchPromise = fetch('/api/ai/recommendation', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        redZoneQuestions: targetQuestions,
                        promptType: promptType,
                        modelProvider: document.getElementById('modelSelect').value,
                        apiKey: apiKey
                    })
                });

                const timerPromise = new Promise(resolve => setTimeout(resolve, 900));
                const [response] = await Promise.all([fetchPromise, timerPromise]);

                if (!response.ok) throw new Error(await response.text());
                const resultText = await response.text();
                aiOutput.innerHTML = `<i class="bi bi-stars text-primary fs-5 mb-2 d-block"></i>${resultText}`;
            } catch (error) {
                aiOutput.innerHTML = `<div class="text-danger fw-bold"><i class="bi bi-exclamation-triangle-fill me-2"></i>${error.message}</div>`;
            }
        }

        async function sendCustomPrompt() {
            const prompt = document.getElementById('customPrompt').value.trim();
            if (!prompt) return alert("Введите текст запроса.");

            const apiKey = document.getElementById('apiKeyInput').value.trim();
            const aiOutput = document.getElementById('ai-output');
            aiOutput.innerHTML = `
                <div class="d-flex align-items-center mb-3">
                    <div class="spinner-grow spinner-grow-sm text-primary me-2" role="status"></div>
                    <span class="fw-semibold text-primary">Обдумываю ответ...</span>
                </div>
            `;

            try {
                const fetchPromise = fetch('/api/ai/custom', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        prompt: prompt,
                        modelProvider: document.getElementById('modelSelect').value,
                        apiKey: apiKey
                    })
                });

                const timerPromise = new Promise(resolve => setTimeout(resolve, 900));
                const [response] = await Promise.all([fetchPromise, timerPromise]);

                if (!response.ok) throw new Error(await response.text());
                const resultText = await response.text();
                aiOutput.innerHTML = `<i class="bi bi-chat-left-text text-primary fs-5 mb-2 d-block"></i>${resultText}`;
            } catch (error) {
                aiOutput.innerHTML = `<div class="text-danger fw-bold"><i class="bi bi-exclamation-triangle-fill me-2"></i>${error.message}</div>`;
            }
        }
    </script>
}